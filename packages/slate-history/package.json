{
  "name": "slate-history",
  "description": "An operation-based history implementation for Slate editors.",
  "version": "0.115.0",
  "license": "MIT",
  "repository": "https://github.com/ianstormtaylor/slate.git",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown --config ../../config/tsdown.config.mts --log-level warn",
    "clean": "rimraf dist lib",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "lodash": "^4.17.21",
    "slate": "workspace:*"
  },
  "peerDependencies": {
    "slate": ">=0.124.2"
  },
  "keywords": [
    "editor",
    "history",
    "operation",
    "redo",
    "save",
    "slate",
    "stack",
    "undo"
  ]
}
